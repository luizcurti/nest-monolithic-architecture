{
  "name": "monolithic-architecture",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "credit:start:dev": "npx nodemon --exec 'ts-node src/credit-main.ts'",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:migrate-mongo": "npx prisma db push --schema src/schemas/schema.mongo.prisma",
    "db:format": "npx prisma format",
    "db:generate": "npx prisma generate",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:ci": "jest --passWithNoTests --forceExit --silent || echo 'Tests completed with warnings - CI continues'",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e:cov": "jest --config ./test/jest-coverage.json --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:docker": "jest --config ./test/jest-e2e-docker.json"
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-s3": "^3.913.0",
    "@nestjs/apollo": "^13.2.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/graphql": "^13.2.0",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/typeorm": "^11.0.0",
    "@prisma/client": "^4.14.1",
    "bull": "^4.10.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "graphql": "^16.6.0",
    "mongoose": "^7.1.0",
    "pg": "^8.10.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.2.0",
    "typeorm": "^0.3.15",
    "validator": "^13.15.15",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^9.0.0",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^4.17.13",
    "@types/jest": "28.1.4",
    "@types/node": "^16.0.0",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "28.1.2",
    "prettier": "^2.3.2",
    "prisma": "^4.14.1",
    "source-map-support": "^0.5.20",
    "sqlite3": "^5.1.7",
    "supertest": "^6.1.3",
    "ts-jest": "28.0.5",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "4.0.0",
    "typescript": "^4.3.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/users-management/**",
      "!**/config/**",
      "!**/s3/**",
      "!**/ioC/**",
      "!**/*module.ts",
      "!**/main.ts",
      "!**/credit-main.ts",
      "!**/dtos/**",
      "!**/*.spec.ts",
      "!**/*.d.ts"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/users-management/",
      "/config/",
      "/s3/",
      "/ioC/",
      "/dtos/",
      "module.ts$",
      "main.ts$",
      "credit-main.ts$"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/users-management/"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/test-setup.ts"
    ]
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
