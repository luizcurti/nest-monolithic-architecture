{
  "displayName": "e2e-coverage",
  "rootDir": "../",
  "testMatch": ["<rootDir>/test/**/*.(e2e-spec|spec).ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "coverageDirectory": "<rootDir>/coverage",
  "collectCoverageFrom": [
    "src/**/*.(t|j)s",
    "!src/**/*.spec.ts",
    "!src/**/*.interface.ts",
    "!src/main.ts",
    "!src/credit-main.ts"
  ],
  "testEnvironment": "node",
  "moduleFileExtensions": ["js", "json", "ts"],
  "testTimeout": 30000,
  "forceExit": true,
  "detectOpenHandles": true
}